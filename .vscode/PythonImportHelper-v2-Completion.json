    {
        "label": "load_data",
        "kind": 2,
        "importPath": "pages.1_💊_OCD_patients_analysis_dashboard",
        "description": "pages.1_💊_OCD_patients_analysis_dashboard",
        "peekOfCode": "def load_data():\n    df = pd.read_csv('ocd_patient_dataset.csv')\n    df['OCD Diagnosis Date'] = pd.to_datetime(df['OCD Diagnosis Date'])\n    df['Diagnosis Year'] = df['OCD Diagnosis Date'].dt.year\n    df['Age Group'] = pd.cut(df['Age'], bins=[0, 18, 30, 45, 60, 100],\n    labels=['<18', '18-30', '31-45', '46-60', '60+'])\n    df['Total Y-BOCS Score'] = df['Y-BOCS Score (Obsessions)'] + df['Y-BOCS Score (Compulsions)']\n    df['Severity Category'] = pd.cut(df['Total Y-BOCS Score'], bins=[0, 7, 15, 23, 31, 40], labels=['Subclinical', 'Mild', 'Moderate', 'Severe', 'Extreme'])\n    df['Comorbidity Profile'] = df.apply(lambda row: 'Both' if row['Depression Diagnosis'] == 'Yes' and row['Anxiety Diagnosis'] == 'Yes'\n    else 'Depression Only' if row['Depression Diagnosis'] == 'Yes'",
        "detail": "pages.1_💊_OCD_patients_analysis_dashboard",
        "documentation": {}
    },
    {
        "label": "encoded_data",
        "kind": 2,
        "importPath": "pages.1_💊_OCD_patients_analysis_dashboard",
        "description": "pages.1_💊_OCD_patients_analysis_dashboard",
        "peekOfCode": "def encoded_data(df):\n    df_encoded = df.copy()\n    categorical_cols = ['Gender', 'Ethnicity', 'Marital Status', 'Education Level', 'Previous Diagnosis', 'Family History of OCD', 'Obsession Type',\n    'Compulsion Type', 'Depression Diagnosis', 'Anxiety Diagnosis', 'Medications']\n    for col in categorical_cols:\n        le = LabelEncoder()\n        df_encoded[col + '_Encoded'] = le.fit_transform(df[col].astype(str))\n        return df_encoded\n    df_encoded = encoded_data(df)\n    df.load_data()",
        "detail": "pages.1_💊_OCD_patients_analysis_dashboard",
        "documentation": {}
    },
